  "keyFeatures": [
    "Email/password registration and login",
    "OTP (passwordless) authentication via email",
    "OAuth integration with Google and Apple using PKCE flow",
    "JWT access and refresh token management via HTTP-only cookies",
    "Secure password reset via email link",
    "Zod schema validation on all endpoints",
    "Structured error responses with consistent error codes",
    "Docker and Cloudflare Workers deployment support"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/signup",
    "POST /api/v1/auth/login",
    "POST /api/v1/auth/login/otp",
    "POST /api/v1/auth/verify-otp",
    "POST /api/v1/auth/refresh",
    "POST /api/v1/auth/logout",
    "POST /api/v1/auth/forgot-password",
    "POST /api/v1/auth/reset-password",
    "GET /api/v1/auth/oauth/:provider",
    "POST /api/v1/auth/oauth/:provider/callback",
    "GET /api/v1/auth/me",
    "POST /api/v1/auth/validate-token"
  ]
}
