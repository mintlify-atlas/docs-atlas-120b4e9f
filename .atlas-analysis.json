{
  "projectType": "api-service",
  "projectName": "Auth Backend",
  "projectDescription": "A production-ready authentication API built with Fastify and Supabase, providing email/password login, OTP, OAuth (Google & Apple), JWT token management, and password reset flows.",
  "theme": "sequoia",
  "primaryColor": "#3B5BDB",
  "lightColor": "#748FFC",
  "darkColor": "#1C2D6B",
